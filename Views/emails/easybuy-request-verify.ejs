<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your EasyBuy Request</title>
  </head>
  <body style="margin:0;padding:0;background:#f5f7fb;font-family:Arial,sans-serif;color:#1f2937;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f5f7fb;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:600px;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
            <tr>
              <td style="padding:24px 24px 8px;">
                <h2 style="margin:0;font-size:22px;line-height:1.3;">Verify your EasyBuy request</h2>
              </td>
            </tr>
            <tr>
              <td style="padding:0 24px 8px;font-size:14px;line-height:1.6;">
                <p style="margin:0 0 12px;">Hi <%= fullName %>,</p>
                <p style="margin:0 0 12px;">
                  Please verify your email to continue processing your EasyBuy request.
                </p>
                <p style="margin:0 0 12px;">
                  <strong>Request ID:</strong> <%= requestId %><br />
                  <strong>Device:</strong> <%= iphoneModel %> (<%= capacity %>)<br />
                  <strong>Plan:</strong> <%= plan %>
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding:8px 24px 16px;">
                <a
                  href="<%= verifyUrl %>"
                  style="display:inline-block;background:#0f172a;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:8px;font-size:14px;font-weight:600;"
                >
                  Verify Email
                </a>
              </td>
            </tr>
            <tr>
              <td style="padding:0 24px 20px;font-size:12px;line-height:1.6;color:#6b7280;">
                If the button does not work, copy and paste this URL into your browser:<br />
                <a href="<%= verifyUrl %>" style="color:#2563eb;word-break:break-word;"><%= verifyUrl %></a>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
